        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykket faller — dårligere vær er på vei. Regn og sterk vind kan komme. Vurder å snu tidlig."
          }
        }
      }
    },
    "weather.pressure.impact.noTrend" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ikke nok data til å vise utviklingen ennå. Sjekk igjen litt senere."
          }
        }
      }
    },
    "weather.pressure.impact.rising" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykket stiger — været bedrer seg. Skyene letter, og vinden roer seg."
          }
