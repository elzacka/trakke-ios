    "weather.uv.impact.extreme" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekstremt sterk UV-stråling. Unngå å oppholde deg ute midt på dagen. Ubeskyttet hud forbrenner på under 15 minutter."
          }
        }
      }
    },
    "weather.uv.impact.high" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solkrem (SPF 15+), solbriller og hatt er nødvendig. Unngå direkte sol midt på dagen. Ubeskyttet hud forbrenner på 30–60 minutter."
          }
        }
      }
    },
    "weather.uv.impact.low" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ingen spesiell beskyttelse nødvendig for de fleste."
          }
        }
      }
    },
    "weather.uv.impact.moderate" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Bruk solkrem, solbriller og hatt. Ubeskyttet hud kan forbrenne på 1–2 timer. Snø og høyde forsterker UV."
          }
        }
      }
    },
    "weather.uv.impact.veryHigh" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sterk UV-stråling. Ubeskyttet hud kan forbrenne på 15–30 minutter. Søk skygge mellom kl. 12 og 15. Solkrem, hatt og solbriller er påkrevd."
          }
        }
      }
    },
    "weather.uv.low" : {
