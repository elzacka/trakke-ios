          }
        }
      }
    },
    "settings.format.mgrs.tooltip" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brukes av NATO og militære styrker for presis navigasjon. Ligner på UTM, men inneholder en bokstavutvidelse som sikrer unike koordinater til ethvert sted på jorda."
          }
        }
      }
    },
    "settings.format.utm.tooltip" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Her: EUREF89 UTM sone 33. Et globalt rutenettbasert koordinatsystem som deler jorden inn i 60 soner, og projiserer disse på en sylinder for å måle posisjoner i meter fremfor grader. I Norge bruker vi vanligvis dette koordinatsystemet for kart som dekker hele Norges fastland."
          }
        }
      }
    },
