          "stringUnit" : {
            "state" : "translated",
            "value" : "Delvis skyet"
          }
        }
      }
    },
    "weather.precip.heavy" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig nedbør"
          }
        }
      }
    },
    "weather.precip.impact.heavy" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig regn gir raskt stigende elver, flomfare og risiko for jordskred. Hold avstand til vassdrag og bratte skråninger. Vurder å avbryte eller utsette turen. Redusert sikt i fjellet."
          }
        }
      }
    },
    "weather.precip.impact.light" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lett yr eller duskregn. Du blir fuktig over tid uten regntøy. Båltenning krever tørt brennmateriale. Stier kan bli glatte. Telt eller gapahuk anbefales for overnatting."
          }
        }
      }
    },
    "weather.precip.impact.moderate" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regntøy er nødvendig. Bekker kan stige raskt. Stier i bratt terreng kan bli til bekkeløp. Bål er vanskelig uten ly. Pakk utstyr vanntett. Flomfare i trange daler."
          }
        }
      }
    },
    "weather.precip.impact.none" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørt vær. Gode forhold for alle typer turer, bål og overnatting ute. Stier og terreng er lettgått."
          }
        }
      }
    },
    "weather.precip.light" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lett nedbør"
          }
        }
      }
    },
    "weather.precip.moderate" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Moderat nedbør"
          }
        }
      }
    },
