    "weather.wind.land.0" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Røyken stiger rett opp."
          }
        }
      }
    },
    "weather.wind.land.1" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En kan se vindretningen av røykens drift."
          }
        }
      }
    },
    "weather.wind.land.2" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "En kan føle vinden. Bladene på trærne rører seg, vinden kan løfte små vimpler."
          }
        }
      }
    },
    "weather.wind.land.3" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Løv og småkvister rører seg. Vinden strekker lette flagg og vimpler."
          }
        }
      }
    },
    "weather.wind.land.4" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vinden løfter støv og løse papirer, rører på kvister og smågreine, strekker større flagg og vimpler."
          }
        }
      }
    },
    "weather.wind.land.5" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Småtrær med løv begynner å svaie. På vann begynner småbølgene å toppe seg."
          }
        }
      }
    },
    "weather.wind.land.6" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Store greiner og mindre stammer rører seg. Det hviner i telefonledninger. Det er vanskelig å bruke paraply. En merker motstand når en går."
          }
        }
      }
    },
    "weather.wind.land.7" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hele trær rører på seg. Det er tungt å gå mot vinden."
          }
        }
      }
    },
    "weather.wind.land.8" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vinden brekker kvister av trærne. Det er tungt å gå mot vinden."
          }
        }
      }
    },
    "weather.wind.land.9" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hele store trær svaier og hiver. Takstein kan blåse ned."
          }
        }
      }
    },
    "weather.wind.land.10" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sjelden inne i landet. Trær rykkes opp med rot. Stor skade på hus."
          }
        }
      }
    },
    "weather.wind.land.11" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forekommer sjelden og følges av store ødeleggelser."
          }
        }
      }
    },
    "weather.wind.land.12" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Forekommer meget sjelden. Uvanlig store ødeleggelser."
          }
        }
      }
    },
    "weather.wind.mountain.0" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Snøfiller daler omtrent rett ned, gjerne i en pendlende bevegelse."
          }
        }
      }
    },
    "weather.wind.mountain.1" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Så vidt følbar. Det er tydelig at snøfillene driver med vinden."
          }
        }
      }
    },
    "weather.wind.mountain.2" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Godt følbar i sterk kulde. Snøfillene beveger seg mer horisontalt enn vertikalt."
          }
        }
      }
    },
    "weather.wind.mountain.3" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vinden merkes tydelig og kan sjenere. Fallende snø synes å bevege seg meget raskere horisontalt enn vertikalt."
          }
        }
      }
    },
    "weather.wind.mountain.4" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Er ubehagelig i kaldt vær og gir merkbar motstand. Fallende snø hvirvler av sted med vinden. Snødrevet mot ansiktet er meget sjenerende."
          }
        }
      }
    },
    "weather.wind.mountain.5" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det blir tungt å gå på ski mot været. Fokksnø som driver langs bakken, hvirvles så høyt at synsvidden nedsettes. Snødrevet pisker i ansiktet."
          }
        }
      }
    },
    "weather.wind.mountain.6" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Det er meget slitsomt å ta seg fram mot været. Snøfokk setter ned sikten til under 1 km. Vanskelig å holde ubeskyttet ansikt mot vinden i lengre tid. Folk flest bør ikke legge ut på tur over snaufjellet ved denne og høyere vindstyrker."
          }
        }
      }
    },
    "weather.wind.mountain.7" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "I motvind må en lute seg fram over skiene og legge stor kraft i stavtakene, selv på flat mark. Det kan være vanskelig å holde se på bena. Snøfokk setter ned sikten til få hundre meter. Vanskelig å orientere seg i terrenget. En skitur i fjellet ved vindstyrke 7 er en stor påkjenning for de fleste."
          }
        }
      }
    },
    "weather.wind.mountain.8" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fjellet står i kok. Kvister og lav fra trærne driver med vinden. Meget vanskelig å gå på skiene. Nesten umulig å bære skiene på nakken. Snøfokk setter ned sikten til under 100 m. Umulig å orientere seg i terrenget. Meget vanskelig å følge selv godt kvistede løyper. Legg ikke ut på tur!"
          }
        }
      }
    },
    "weather.wind.mountain.9" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Vind og snøfokk gjør det umulig å ta seg fram på ski over fjellet. Selv i klarvær og lite snøfokk kan påkjenningen bli så stor at en snøhule eller hytte er eneste redning."
          }
        }
      }
    },
    "weather.wind.mountain.10" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Denne og høyere vindstyrker vil de fleste aldri komme ut for. Trær velter over ledninger for telefon og strøm. Det knaker i tømmervegger. Lette småhus rives av grunnmuren."
          }
        }
      }
    },
    "weather.wind.mountain.11" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Veier og jernbanelinjer blokkeres. Det er kaos på telefon- og strømnettet. Skog blir rasert."
          }
        }
      }
    },
    "weather.wind.mountain.12" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Hvis bebyggelse rammes blir det en naturkatastrofe som gjerne vil kreve flere menneskeliv."
          }
        }
      }
    },
    "weather.wind.onLand" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "På land"
          }
        }
      }
    },
    "weather.wind.onMountain" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "På fjellet"
          }
        }
      }
    },
    "weather.wind.tapHint" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trykk for beskrivelse"
          }
        }
      }
    },
    "z%@-%@" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "z%1$@-%2$@"
          }
        }
      }
    }
  },
  "version" : "1.1"
