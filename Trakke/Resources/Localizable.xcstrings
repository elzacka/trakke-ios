          "stringUnit" : {
            "state" : "translated",
            "value" : "Snøbyger"
          }
        }
      }
    },
    "weather.sunrise" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Soloppgang"
          }
        }
      }
    },
    "weather.sunset" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Solnedgang"
          }
        }
      }
    },
    "weather.temp.impact.cold" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kaldt. Kle deg godt med ull innerst og vindtett ytterst. Ta ekstra klær i sekken. Finn ly i pauser. Varme drikker og matpauser er viktige for å holde varmen."
          }
        }
      }
    },
    "weather.temp.impact.cool" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kjølig. Behagelig turtemperatur med riktige klær. God for krevende turer. Ta med ekstra lag til pauser og kveld. Overnatting ute krever sovepose for lave temperaturer."
          }
        }
      }
    },
    "weather.temp.impact.extremeCold" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ekstrem kulde. Fare for forfrysninger på bar hud i løpet av minutter. Kun korte turer med riktig utstyr. Dekk til alt eksponert hud. Ha nødproviant og ekstra klær. Slitasje på batteri og elektronikk."
          }
        }
      }
    },
    "weather.temp.impact.mild" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mildt. Ideelt for de fleste typer friluftsaktiviteter. Lett bekledning holder. Godt for bading hvis vannet er varmt nok. Fine forhold for telt og overnatting ute."
          }
        }
      }
    },
    "weather.temp.impact.veryCold" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svært kaldt. Lag-på-lag-prinsippet er avgjørende. Fare for nedkjøling ved pauser. Hold deg i bevegelse. Varm drikke og energirik mat er viktig. Sørg for at vindtett ytterlag er på plass."
          }
        }
      }
    },
    "weather.temp.impact.warm" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varmt. Husk solkrem og nok drikkevann. Unngå de mest intense timene midt på dagen i direkte sol. Gode badeforhold. Lett å tørke klær og utstyr. Pass på at mat ikke blir dårlig."
          }
        }
      }
    },
    "weather.title" : {
