    "weather.wind.context.east" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørr innlandsluft betyr ofte lite nedbør, men vinterstid kan det bli bitende kaldt."
          }
        }
      }
    },
    "weather.wind.context.north" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kald luft fra Arktis betyr ofte skarpt vær — ta med varme lag uansett årstid."
          }
        }
      }
    },
    "weather.wind.context.northeast" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørr og kald kontinentalluft gir gjerne klart vær, men bitt i lufta. Ekstra hansker og lue er lurt."
          }
        }
      }
    },
    "weather.wind.context.northwest" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ustabil og kald havluft gir gjerne raskskiftende vær med byger — det kan gå fra sol til sludd på en halvtime."
          }
        }
      }
    },
    "weather.wind.context.south" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Mild luft gir gjerne behagelig temperatur, men ofte skyer og litt nedbør."
          }
        }
      }
    },
    "weather.wind.context.southeast" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Varm og tørr luft fra kontinentet gir gjerne fint vær om sommeren, men kan bli trykkende varmt i lavlandet."
          }
        }
      }
    },
    "weather.wind.context.southwest" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuktig Atlanterhavsluft gir gjerne regn og vind. Ha regnjakka lett tilgjengelig, ikke i bunnen av sekken."
          }
        }
      }
    },
    "weather.wind.context.west" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig Atlanterhavspåvirkning betyr ofte mye nedbør og kuling, særlig på fjellet og langs vestkysten."
          }
        }
      }
    },
    "weather.wind.from %@" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
