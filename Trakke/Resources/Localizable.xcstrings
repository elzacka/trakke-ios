    "settings.format.dd.tooltip" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Brukes ofte i geografiske informasjonssystemer (GIS), kartprogrammer for web, som Google Maps samt GPS-mottakere for å uttrykke koordinater med bredde og lengde uten å bruke minutter og sekunder."
          }
        }
      }
    },
    "settings.format.dms.tooltip" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Deler en sirkel inn i 360 grader, hver grad i 60 bueminutter og hvert minutt i 60 buesekunder. Brukes primært til navigasjon, kartografi, geodesi og astronomi. GPS-enheter og kart støtter ofte input i DMS for nøyaktig posisjonering."
          }
        }
      }
    },
    "settings.format.example" : {
