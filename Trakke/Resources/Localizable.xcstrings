    "weather.humidity" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Fuktighet"
          }
        }
      }
    },
    "weather.humidity.impact.high" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Høy fuktighet. Svette fordamper saktere, og du kan bli klam. Sovepose og klær tørker langsomt. Tåke er vanlig i daler og langs kysten. Mygg trives."
          }
        }
      }
    },
    "weather.humidity.impact.low" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørr luft. Behagelig å bevege seg i, men husk å drikke nok vann. Tørt terreng gir økt skogbrannfare. Vis forsiktighet med bål og engangsgrill."
          }
        }
      }
    },
    "weather.humidity.impact.moderate" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Normal fuktighet. Gode forhold for friluftsliv. Klær tørker greit. Godt bålvær med vanlig forsiktighet."
          }
        }
      }
    },
    "weather.humidity.impact.veryHigh" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svært fuktig luft, ofte nær tåke eller regn. Klær og utstyr holder seg fuktige. Økt risiko for nedkjøling selv ved moderate temperaturer. Tørk utstyr godt etter turen."
          }
        }
      }
    },
    "weather.humidity.label" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "luftfuktighet"
          }
        }
      }
    },
