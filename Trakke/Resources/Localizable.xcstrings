    "weather.precip.feels.drizzle" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Yr eller lett snø — du kjenner det i ansiktet, men blir knapt våt."
          }
        }
      }
    },
    "weather.precip.feels.heavy" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig nedbør — dårlig sikt og vanskelige forhold. Full regnbekledning og gamasjer er nødvendig."
          }
        }
      }
    },
    "weather.precip.feels.light" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lett nedbør — du merker det godt. Skalljakke holder deg tørr."
          }
        }
      }
    },
    "weather.precip.feels.moderate" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Jevn nedbør — du blir våt uten skallklær. Stier blir glatte og det kan bli mer vann i bekker og elver."
          }
        }
      }
    },
    "weather.precip.feels.none" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørt — ingen nedbør å merke."
          }
        }
      }
    },
    "weather.precip.feels.torrential" : {
      "extractionState" : "manual",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Svært kraftig nedbør — farevarsel-nivå. Fare for flom i bekker og elver. Søk ly og hold avstand til vassdrag."
          }
        }
      }
    },
    "weather.precip.heavy" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig nedbør"
          }
        }
      }
    },
    "weather.precip.impact.heavy" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kraftig regn gir raskt stigende elver, flomfare og risiko for jordskred. Hold avstand til vassdrag og bratte skråninger. Vurder å avbryte eller utsette turen. Redusert sikt i fjellet."
          }
        }
      }
    },
    "weather.precip.impact.light" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lett yr eller duskregn. Du blir fuktig over tid uten regntøy. Båltenning krever tørt brennmateriale. Stier kan bli glatte. Telt eller gapahuk anbefales for overnatting."
          }
        }
      }
    },
    "weather.precip.impact.moderate" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Regntøy er nødvendig. Bekker kan stige raskt. Stier i bratt terreng kan bli til bekkeløp. Bål er vanskelig uten ly. Pakk utstyr vanntett. Flomfare i trange daler."
          }
        }
      }
    },
    "weather.precip.impact.none" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Tørt vær. Gode forhold for alle typer turer, bål og overnatting ute. Stier og terreng er lettgått."
          }
        }
      }
    },
    "weather.precip.light" : {
      "extractionState" : "stale",
      "localizations" : {
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Lett nedbør"
          }
        }
      }
    },
